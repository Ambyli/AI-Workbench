# Build context is the REPO ROOT (see ai/docker-compose.roofix.yml: context: ..)
# so we can copy the shared workspace package alongside the service.

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_NO_CACHE=1 \
    PYTHONPATH=/app/ai/roofix/bridge

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Workspace bootstrap.
COPY pyproject.toml .
COPY shared/common ./shared/common
COPY ai/roofix/bridge/pyproject.toml ./ai/roofix/bridge/

RUN uv sync --package roofix-bridge --no-dev

# Service code.
COPY ai/roofix/bridge/app.py ./ai/roofix/bridge/
COPY ai/roofix/bridge/components ./ai/roofix/bridge/components
COPY ai/roofix/bridge/config ./ai/roofix/bridge/config

WORKDIR /app/ai/roofix/bridge
EXPOSE 8080

CMD ["uv", "run", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8080"]
